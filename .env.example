# Supabase — obtenelos en https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Login por SMS: activar solo cuando haya proveedor (Twilio) configurado en Supabase
VITE_ENABLE_PHONE_AUTH=false

# PostHog (product analytics) — opcional. Sin la key, el tracking queda apagado.
# Key: PostHog → Settings → Project → Project API Key (empieza con phc_)
VITE_POSTHOG_KEY=
# Host: US = https://us.i.posthog.com (default) · EU = https://eu.i.posthog.com
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Web Push (notificaciones con la app cerrada) — opcional. Sin esta key, el
# push queda apagado (el sonido y los avisos in-app/del navegador siguen
# andando igual). Generá el par con:  npx web-push generate-vapid-keys
# Acá va la PÚBLICA; la privada va como secret de la Edge Function send-push
# (supabase secrets set VAPID_PRIVATE_KEY=...). Tienen que ser el mismo par.
VITE_VAPID_PUBLIC_KEY=
